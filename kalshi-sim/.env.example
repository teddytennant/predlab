# Kalshi Simulator Environment
# Copy to .env and edit for local dev

# Server
ENVIRONMENT=development
PORT=8002
LOG_LEVEL=INFO

# Database (SQLite for foundation; switch to postgres:// later)
DATABASE_URL=sqlite:///./data/kalshi_sim.db

# Starting paper balance in cents (e.g. $25,000 = 2500000)
STARTING_BALANCE_CENTS=2500000

# Sync interval seconds for live market data
SYNC_INTERVAL_SECONDS=60

# Kalshi upstream (public, no key needed for market data)
KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2

# Optional: club secret for admin ops later
CLUB_ADMIN_SECRET=change-me-in-prod

# Phase 2 dev: bypass RSA signature verification for easy local testing with curls
# Set to false for realistic SDK + signature testing
DEV_BYPASS_AUTH=true

# For future Redis (orderbook cache)
# REDIS_URL=redis://localhost:6379/0
