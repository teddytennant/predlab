# Polymarket-sim configuration
# Copy to .env and edit for local dev

# Database (sqlite for quick start; postgres for prod via docker)
DATABASE_URL=sqlite:///./data/polymarket.db

# Server
ENVIRONMENT=development
PORT=8001
HOST=0.0.0.0

# Sync service
SYNC_INTERVAL_SECONDS=60
GAMMA_API_BASE=https://gamma-api.polymarket.com

# Paper trading defaults
STARTING_BALANCE_USD=25000.00

# Admin / seed (used for /admin/* privileged endpoints and scripts)
ADMIN_SECRET=change-me-in-prod-for-club-use-only
