# PredLab deployment config.
# Copy to `.env` and fill in real values BEFORE exposing this publicly:
#     cp .env.example .env && $EDITOR .env
# docker compose reads `.env` automatically for ${VAR} interpolation.

# Run mode. "production" for the live club deployment.
ENVIRONMENT=production

# Polymarket admin endpoints (e.g. /admin/create-paper-key) are gated by the
# X-Admin-Secret header. Generate a long random value: `openssl rand -hex 32`
ADMIN_SECRET=change-me-generate-with-openssl-rand-hex-32

# Kalshi admin endpoints (key generation, user reset) are gated by this.
CLUB_ADMIN_SECRET=change-me-generate-with-openssl-rand-hex-32

# Kalshi only. Keep FALSE in production so unsigned requests are rejected and
# students must use real issued keys. Set true only for local SDK tinkering.
DEV_BYPASS_AUTH=false
